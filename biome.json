{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "files": {
    "includes": ["static/**"]
  },
  "linter": {
    "enabled": false
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "css": {
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "javascript": {
    "formatter": {
      "semicolons": "asNeeded",
      "quoteStyle": "single",
      "arrowParentheses": "asNeeded",
      "trailingCommas": "all",
      "bracketSpacing": true
    }
  },
  "html": {
    "formatter": {
      "enabled": true
    },
    "parser": {
      "interpolation": true
    }
  },
  "overrides": [
    {
      "includes": ["static/result.html"],
      "formatter": {
        "enabled": false
      }
    }
  ]
}
